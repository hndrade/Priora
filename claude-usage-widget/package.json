{
  "name": "claude-usage-widget",
  "version": "1.0.0",
  "description": "Widget flutuante para Windows com o uso de rate-limit do Claude Code (porte do Claude Usage Stick)",
  "main": "main.js",
  "author": "hndrade",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.hndrade.claude-usage-widget",
    "productName": "Claude Usage Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "portable": {
      "artifactName": "ClaudeUsageWidget-${version}.exe"
    }
  }
}
